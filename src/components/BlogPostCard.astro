---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import AuthorBadge from '@/components/AuthorBadge.astro';
import Icon from '@/components/Icon.astro';

interface Props {
  post: CollectionEntry<'blog'>;
  priority?: boolean;
}

const { post, priority = false } = Astro.props;
const date = post.data.pubDate.toLocaleDateString('es-CO', {
  day: '2-digit',
  month: 'short',
  year: 'numeric',
  timeZone: 'UTC',
});
---

<article class="group border-t border-steel py-7 first:border-t-0 first:pt-0">
  <a
    href={`/blog/${post.id}/`}
    class="grid gap-5 rounded-2xl px-1 py-2 transition duration-200 hover:bg-steel/40 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-acid motion-reduce:transition-none sm:grid-cols-[13rem_1fr_auto] sm:items-start sm:gap-6 sm:px-4 sm:py-5"
  >
    <div>
      <Image
        src={post.data.image}
        alt={post.data.imageAlt}
        widths={[416, 832]}
        sizes="(min-width: 640px) 208px, 100vw"
        loading={priority ? 'eager' : 'lazy'}
        fetchpriority={priority ? 'high' : 'auto'}
        decoding="async"
        class="aspect-video w-full rounded-xl border border-steel object-cover"
      />
      <div class="mt-3 flex items-center gap-3 font-mono text-[11px] tracking-[0.12em] text-smoke uppercase sm:flex-col sm:items-start sm:gap-1">
        <time datetime={post.data.pubDate.toISOString()}>{date}</time>
        <span>{post.data.readingTime} de lectura</span>
      </div>
    </div>

    <div>
      <h2 class="font-display text-xl font-semibold leading-tight tracking-tight text-bone transition-colors group-hover:text-acid sm:text-2xl">
        {post.data.title}
      </h2>
      <p class="mt-3 max-w-2xl text-sm font-light leading-6 text-smoke sm:text-[15px] sm:leading-7">
        {post.data.description}
      </p>
      <div class="mt-4">
        <AuthorBadge compact />
      </div>
      <div class="mt-4 flex flex-wrap gap-2">
        {
          post.data.tags.map((tag) => (
            <span class="rounded-md border border-steel bg-void px-2.5 py-1 font-mono text-[10px] tracking-wider text-smoke uppercase">
              {tag}
            </span>
          ))
        }
      </div>
    </div>

    <span class="hidden h-9 w-9 items-center justify-center rounded-lg border border-steel bg-void transition-colors group-hover:border-acid sm:flex">
      <Icon name="arrow-up-right" size={15} class="h-4 w-4" />
    </span>
  </a>
</article>
