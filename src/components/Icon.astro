---
import * as lucide from 'lucide';
import {
  siSubstack,
  siInstagram,
  siX,
  siThreads,
  siFacebook,
  siTiktok,
  siWhatsapp,
} from 'simple-icons';
import linkedin from '@/assets/icons/linkedin.svg';

const simpleIcons = {
  substack: siSubstack,
  instagram: siInstagram,
  x: siX,
  threads: siThreads,
  facebook: siFacebook,
  tiktok: siTiktok,
  whatsapp: siWhatsapp,
} as const;

const localIcons: Record<string, string> = {
  linkedin: linkedin.src,
};

export type IconName = 'lucide:arrow-up-right' | 'lucide:book-open' | 'lucide:calendar' | 'simple:facebook' | 'simple:instagram' | 'simple:substack' | 'simple:threads' | 'simple:tiktok' | 'simple:whatsapp' | 'simple:x' | 'linkedin';

type Props = {
  name: IconName;
  size?: number;
  class?: string;
};

const { name, size = 18, class: className = '' } = Astro.props;

const toPascal = (value: string): string =>
  value
    .split('-')
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join('');

const renderLucide = (key: string): string => {
  const data = (lucide.icons as Record<string, Array<[string, Record<string, string>]>>)[key];
  if (!data) {
    throw new Error(`Lucide icon not found: ${key}`);
  }
  const inner = data
    .map(([tag, attrs]) => {
      const attrsStr = Object.entries(attrs)
        .filter(([k]) => k !== 'key')
        .map(([k, v]) => `${k}="${v}"`)
        .join(' ');
      return `<${tag} ${attrsStr}/>`;
    })
    .join('');
  return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="${size}" height="${size}" class="${className}" aria-hidden="true">${inner}</svg>`;
};

const renderSimple = (key: keyof typeof simpleIcons): string => {
  const data = simpleIcons[key];
  return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="${size}" height="${size}" class="${className}" aria-hidden="true"><path d="${data.path}"/></svg>`;
};

const renderLocal = (key: string): string => {
  const src = localIcons[key];
  if (!src) {
    throw new Error(`Local icon not found: ${key}`);
  }
  return `<img src="${src}" alt="" width="${size}" height="${size}" class="${className}" aria-hidden="true" />`;
};

let svg = '';
if (name.startsWith('lucide:')) {
  svg = renderLucide(toPascal(name.slice('lucide:'.length)));
} else if (name.startsWith('simple:')) {
  svg = renderSimple(name.slice('simple:'.length) as keyof typeof simpleIcons);
} else {
  svg = renderLocal(name);
}
---
<Fragment set:html={svg} />
