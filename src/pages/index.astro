---
import { Image } from 'astro:assets';
import avatar from '@/assets/avatar-profile.png';
import logo from '@/assets/logo.svg';
import Icon from '@/components/Icon.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { links, profile, socialLinks } from '@/data/links';
---

<BaseLayout>
  <main
    id="main"
    class="relative mx-auto flex min-h-dvh w-full max-w-3xl flex-col px-5 py-8 sm:px-8 sm:py-12"
  >
    <section
      class="relative overflow-hidden rounded-[2rem] border border-steel bg-graphite px-5 py-8 shadow-2xl shadow-black/40 sm:px-10 sm:py-11"
      aria-labelledby="profile-name"
    >
      <div
        aria-hidden="true"
        class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-acid/60 to-transparent"
      >
      </div>

      <header class="flex flex-col items-center text-center">
        <div class="mb-6 flex w-full items-center justify-between">
          <span class="font-mono text-[10px] tracking-[0.24em] text-smoke uppercase">
            Perfil digital
          </span>
          <Image
            src={logo}
            alt="Logotipo JM"
            width={50}
            loading="eager"
            class="h-auto w-10 sm:w-12"
          />
        </div>

        <div class="relative">
          <div
            aria-hidden="true"
            class="absolute -inset-2 rounded-full border border-acid/20"
          >
          </div>
          <Image
            src={avatar}
            alt="Retrato de Juan Maldonado"
            width={224}
            height={224}
            format="webp"
            quality={90}
            class="relative h-28 w-28 rounded-full border-2 border-steel object-cover shadow-xl shadow-black/50 sm:h-32 sm:w-32"
            loading="eager"
            fetchpriority="high"
          />
          <span
            class="absolute right-1 bottom-1 h-4 w-4 rounded-full border-4 border-graphite bg-acid"
            aria-hidden="true"
          >
          </span>
        </div>

        <p class="mt-7 font-mono text-[11px] font-semibold tracking-[0.22em] text-acid uppercase">
          Tecnología · Negocio digital · Sistemas
        </p>
        <h1
          id="profile-name"
          class="mt-3 font-display text-4xl font-bold tracking-[-0.035em] text-bone sm:text-5xl"
        >
          {profile.name}
        </h1>
        <p class="mt-2 font-mono text-sm text-smoke">{profile.handle}</p>
        <p class="mt-5 max-w-lg text-[15px] font-light leading-7 text-bone sm:text-base">
          {profile.description}
        </p>
      </header>

      <nav class="mt-10" aria-label="Enlaces principales">
        <h2 class="sr-only">Consultoría, artículos y blog</h2>
        <ul class="flex flex-col gap-3">
          {
            links.map((link) => (
              <li>
                <a
                  href={link.href}
                  target={link.newTab || link.href.startsWith('http') ? '_blank' : undefined}
                  rel={link.newTab || link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                  class:list={[
                    'group flex min-h-20 items-center gap-4 rounded-2xl border px-4 py-4 transition duration-200 hover:-translate-y-0.5 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-acid motion-reduce:transform-none motion-reduce:transition-none sm:px-5',
                    link.featured
                      ? 'border-acid bg-void hover:bg-steel'
                      : 'border-steel bg-void hover:border-smoke hover:bg-steel',
                  ]}
                >
                  <span
                    class:list={[
                      'flex h-11 w-11 shrink-0 items-center justify-center rounded-xl border',
                      link.featured
                        ? 'border-acid bg-graphite'
                        : 'border-steel bg-graphite',
                    ]}
                  >
                    <Icon name={link.icon} size={21} class="h-5 w-5" />
                  </span>

                  <span class="min-w-0 flex-1">
                    <span class="block font-display text-[15px] font-semibold text-bone sm:text-base">
                      {link.title}
                    </span>
                    <span class="mt-1 block text-xs font-light leading-5 text-smoke sm:text-[13px]">
                      {link.description}
                    </span>
                  </span>

                  <span
                    class="hidden shrink-0 items-center gap-1.5 font-mono text-[10px] tracking-wider text-smoke uppercase transition-colors group-hover:text-acid sm:flex"
                  >
                    {link.action}
                    <Icon name="arrow-up-right" size={14} class="h-3.5 w-3.5" />
                  </span>
                  {(link.newTab || link.href.startsWith('http')) && (
                    <span class="sr-only"> (se abre en una pestaña nueva)</span>
                  )}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <nav
        class="mt-9 border-t border-steel pt-7"
        aria-label="Redes sociales"
      >
        <h2 class="sr-only">Redes sociales de Juan Maldonado</h2>
        <ul class="flex flex-wrap items-center justify-center gap-2.5 sm:gap-3">
          {
            socialLinks.map((social) => (
              <li>
                <a
                  href={social.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`${social.name} (se abre en una pestaña nueva)`}
                  title={social.name}
                  class="group flex h-11 w-11 items-center justify-center rounded-xl border border-steel bg-void transition duration-200 hover:-translate-y-0.5 hover:border-acid hover:bg-steel focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-acid motion-reduce:transform-none motion-reduce:transition-none"
                >
                  <Icon
                    name={social.icon}
                    size={20}
                    class="h-5 w-5 opacity-75 transition-opacity group-hover:opacity-100"
                  />
                </a>
              </li>
            ))
          }
        </ul>
      </nav>
    </section>

    <footer
      class="mt-6 flex items-center justify-center gap-2 font-mono text-[11px] tracking-[0.14em] text-smoke uppercase"
    >
      <span class="h-1.5 w-1.5 rounded-full bg-acid/70"></span>
      <span>juanmaldonado.digital · {new Date().getFullYear()}</span>
    </footer>
  </main>
</BaseLayout>
