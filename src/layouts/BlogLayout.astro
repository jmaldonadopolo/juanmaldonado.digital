---
import { Image } from 'astro:assets';
import logo from '@/assets/logo.svg';
import BaseLayout from '@/layouts/BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  imageAlt?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  tags?: string[];
  structuredData: Record<string, unknown>[];
}

const {
  title,
  description,
  ogImage,
  imageAlt,
  type = 'website',
  publishedTime,
  modifiedTime,
  tags = [],
  structuredData,
} = Astro.props;

const currentPath = Astro.url.pathname;
const onBlog = currentPath.startsWith('/blog');
const onHome = currentPath === '/';

const navLinkClass = (active: boolean): string => [
  'rounded-lg px-3.5 py-2 font-mono text-[11px] tracking-wider uppercase focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-acid motion-reduce:transition-none',
  active
    ? 'bg-steel font-semibold text-acid'
    : 'text-smoke transition-colors hover:bg-steel hover:text-bone',
].join(' ');
---

<BaseLayout
  title={title}
  description={description}
  ogImage={ogImage}
  imageAlt={imageAlt}
  type={type}
  publishedTime={publishedTime}
  modifiedTime={modifiedTime}
  tags={tags}
  structuredData={structuredData}
>
  <div class="relative mx-auto min-h-dvh w-full max-w-5xl px-5 pb-16 sm:px-8">
    <header class="sticky top-0 z-20 border-b border-steel bg-void/90 py-4 backdrop-blur-xl">
      <nav class="flex items-center justify-between" aria-label="Navegación del blog">
        <a
          href="/"
          aria-label="Ir al perfil de Juan Maldonado"
          class="flex min-h-11 items-center rounded-md px-1 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-acid"
        >
          <Image
            src={logo}
            alt=""
            width={64}
            loading="eager"
            class="h-auto w-12 sm:w-14"
          />
        </a>

        <div class="flex items-center gap-1 rounded-xl border border-steel bg-graphite p-1">
          <a
            href="/blog/"
            aria-current={onBlog ? 'page' : undefined}
            class={navLinkClass(onBlog)}
          >
            Blog
          </a>
          <a
            href="/"
            aria-current={onHome ? 'page' : undefined}
            class={navLinkClass(onHome)}
          >
            Inicio
          </a>
        </div>
      </nav>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="mt-16 flex flex-col items-center gap-3 border-t border-steel pt-7 text-center font-mono text-[11px] tracking-[0.14em] text-smoke uppercase sm:flex-row sm:justify-between">
      <span>juanmaldonado.digital · {new Date().getFullYear()}</span>
      <nav aria-label="Navegación secundaria" class="flex items-center gap-4">
        <a
          href="/"
          class="rounded-sm transition-colors hover:text-bone focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-acid motion-reduce:transition-none"
        >
          Volver al inicio
        </a>
        <span aria-hidden="true" class="text-steel">·</span>
        <a
          href="/rss.xml"
          class="rounded-sm transition-colors hover:text-bone focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-acid motion-reduce:transition-none"
        >
          RSS
        </a>
      </nav>
    </footer>
  </div>
</BaseLayout>
